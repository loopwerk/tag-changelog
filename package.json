{
  "name": "tag-changelog",
  "version": "0.0.1",
  "description": "Automatically generate a changelog since the last tag, using the conventional commit format",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "package": "pnpm run check && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "act": "pnpm run package && act",
    "check": "eslint src test --fix && tsc --noEmit",
    "test": "mocha --require tsx 'test/*.spec.ts'",
    "format": "prettier --write ."
  },
  "author": "Loopwerk",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@conventional-commits/parser": "^0.4.1",
    "compare-versions": "^6.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@octokit/openapi-types": "^27.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0"
  }
}
